# KitfoxPay 环境变量 / Environment Variables
#
# 所有业务配置（Jeepay、Paystack、e-pay、管理密码等）通过管理界面设置，不需要环境变量。
# All business config (Jeepay, Paystack, e-pay, admin password, etc.) is set via the admin UI.
# No environment variables are needed for those.
#
# ─────────────────────────────────────────────────────────────
# DATABASE_URL（可选 / Optional）
# ─────────────────────────────────────────────────────────────
#
# 作用 / Purpose:
#   1. 配置持久化 / Config persistence
#      管理界面保存的配置存入数据库，重启或重新部署后自动恢复，无需重新配置。
#      Config saved via admin UI is stored in the database and auto-restored on restart/redeploy.
#
#   2. 会话持久化 / Session persistence
#      管理员登录状态跨重启保持，无需重新登录。
#      Admin login session persists across restarts.
#
#   3. Webhook 幂等性 / Webhook idempotency
#      防止同一支付通知被重复处理，跨重启保持去重记录。
#      Prevents duplicate payment processing; deduplication records survive restarts.
#
# 不设置时的行为 / Behavior without DATABASE_URL:
#   - 配置仅保存到本地文件（重新部署后丢失）/ Config saved to local file only (lost on redeploy)
#   - 使用有界内存会话存储（安全，无内存泄漏）/ Uses bounded memory session store (safe, no leak)
#   - Webhook 幂等性使用进程内存（重启后失效）/ Webhook idempotency uses process memory (cleared on restart)
#   应用功能完整，DATABASE_URL 仅影响数据跨部署的持久化能力。
#   App is fully functional; DATABASE_URL only affects whether data survives redeployment.
#
# 格式 / Format:
#   postgresql://[user]:[password]@[host]:[port]/[database]
#
# 首次启动自动建表，无需手动执行任何 SQL。
# Tables are created automatically on first run — no manual SQL needed.
#
# 兼容任何标准 PostgreSQL 服务 / Compatible with any standard PostgreSQL service.

DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────────
# SERVER_PORT（可选 / Optional）
# ─────────────────────────────────────────────────────────────
# 覆盖 config.js 中配置的监听端口。
# Overrides the listen port configured in config.js.
# 默认 / Default: 9219
#
# SERVER_PORT=9219
